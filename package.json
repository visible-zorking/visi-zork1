{
  "name": "VisiZork-Zork1",
  "version": "1.0",
  "description": "An interactive fiction visualizer",
  "author": "Andrew Plotkin <erkyrath@eblong.com>",
  "license": "MIT",
  "scripts": {
    "buildall": "pnpm run buildjs && pnpm run builddata",
    "buildjs": "pnpm run minify && pnpm run buildts",
    "buildts": "pnpm exec tsc && pnpm exec rollup -c",
    "minify": "./minify gamedat.js && ./minify lib.js && ./minify glkio.js && ./minify ifvms.js && ./minify gnusto.js && ./minify parchment.js",
    "builddata": "pnpm run recreate-gamedata && pnpm run rearrange-tables && pnpm run recolor-source && pnpm run regenerate-commentary && pnpm run reparse-map",
    "recreate-gamedata": "python3 visiterp/pyana/parse.py --game zork1-r88-s840726 -z gamesrc/zork1.zil --obj --dict --grammar --txd --gamedat",
    "rearrange-tables": "python3 visiterp/pyana/parse.py --game zork1-r88-s840726 -z gamesrc/zork1.zil --zcode gamedat/zork1-r88-s840726.z3 --gamedat",
    "recolor-source": "python3 visiterp/pyana/parse.py --game zork1-r88-s840726 -z gamesrc/zork1.zil --src",
    "regenerate-commentary": "python3 visiterp/pyana/comgen.py gamedat/commentary",
    "reparse-map": "python3 visiterp/pyana/mapparse.py gamedat/zork1-map.svg"
  },
  "type": "module",
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "28.0.0",
    "@rollup/plugin-node-resolve": "15.3.1",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-terser": "0.4.4",
    "@types/node": "22.19.15",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "rollup": "4.59.0",
    "terser": "5.46.1",
    "typescript": "5.9.3"
  }
}
